# thesis-agent environment variables
# Copy to .env and fill in your keys

# Required: Anthropic API key (powers the evaluation engine)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Companies House API key
# Free — register at https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# Optional: GitHub personal access token
# Free — increases rate limit from 60 to 5,000 requests/hour
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional: Adzuna API credentials (hiring signal tracking)
# Free tier: 250 requests/day across 16 countries
# Register at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
