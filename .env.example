# thesis-radar environment variables
# Copy to .env and fill in your keys

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Companies House API key (free, register at https://developer.company-information.service.gov.uk/)
COMPANIES_HOUSE_API_KEY=

# Optional: Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
